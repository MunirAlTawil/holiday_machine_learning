# DataTourisme API Configuration
# Copy this file to .env and fill in your actual API key
# DO NOT commit the .env file to version control

# DataTourisme API Key (required)
DATATOURISME_API_KEY=put_your_key_here

# Base URL for DataTourisme API (optional, defaults to https://api.datatourisme.fr)
# BASE_URL=https://api.datatourisme.fr